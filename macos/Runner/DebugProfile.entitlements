<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Sandbox: obbligatoria per Mac App Store -->
	<key>com.apple.security.app-sandbox</key>
	<true/>

	<!-- Rete: abilita se l'app fa chiamate a internet -->
	<key>com.apple.security.network.client</key>
	<true/>

	<!-- Abilita solo ciò che serve alla tua app: -->

	<!-- Accesso in lettura ai file scelti dall'utente -->
	<!-- <key>com.apple.security.files.user-selected.read-only</key>
	<true/> -->

	<!-- Accesso in lettura/scrittura ai file scelti dall'utente -->
	<!-- <key>com.apple.security.files.user-selected.read-write</key>
	<true/> -->

	<!-- Fotocamera -->
	<!-- <key>com.apple.security.device.camera</key>
	<true/> -->

	<!-- Microfono -->
	<!-- <key>com.apple.security.device.microphone</key>
	<true/> -->
</dict>
</plist>
